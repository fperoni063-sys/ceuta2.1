# WhatsApp (for floating button)
NEXT_PUBLIC_WHATSAPP_BOT=+59898910715
NEXT_PUBLIC_WHATSAPP_JULIA=+59898843651

# Site URL (change in production)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
